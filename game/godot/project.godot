; Engine configuration file — Godot 4.2+
config_version=5

[application]
config/name="TVGuy"
config/description="Horror ARG — um jogo sobre frequências perdidas"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]
Game="*res://scripts/autoload/Game.gd"
Inventory="*res://scripts/autoload/Inventory.gd"
AudioMgr="*res://scripts/autoload/AudioMgr.gd"

[display]
window/size/viewport_width=640
window/size/viewport_height=360
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input]
move_forward={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":87,"script":null), Object(InputEventKey,"physical_keycode":4194320,"script":null)]
}
move_back={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":83,"script":null), Object(InputEventKey,"physical_keycode":4194322,"script":null)]
}
move_left={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":65,"script":null), Object(InputEventKey,"physical_keycode":4194319,"script":null)]
}
move_right={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":68,"script":null), Object(InputEventKey,"physical_keycode":4194321,"script":null)]
}
interact={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":69,"script":null), Object(InputEventKey,"physical_keycode":32,"script":null)]
}
crouch={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":4194306,"script":null), Object(InputEventKey,"physical_keycode":67,"script":null)]
}
uv_toggle={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":70,"script":null)]
}
pause={
"deadzone": 0.2,
"events": [Object(InputEventKey,"physical_keycode":4194305,"script":null)]
}

[physics]
3d/default_gravity=9.8

[rendering]
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
