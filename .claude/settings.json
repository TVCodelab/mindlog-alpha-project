{
  "mcpServers": {
    "godot": {
      "command": "npx",
      "args": ["-y", "godot-mcp"],
      "env": {
        "GODOT_PROJECT_PATH": "${workspaceFolder}/game"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}/game"
      ]
    },
    "shell": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-bash-minimal"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(godot:*)",
      "Bash(npm:*)",
      "Bash(npx:*)"
    ]
  }
}
